# hermes-qiweidoc — environment template.
# Copy the values you need into ~/.hermes/.env (NOT committed).
# `hermes plugins install` will prompt for and write QIWEIDOC_PAT for you;
# the rest you set by hand. Never commit real secrets.

# --- qiweidoc channel (required) ---
# Personal access token from the `lumist auth login` / /api/cli/whoami flow.
QIWEIDOC_PAT=

# Base URL of the qiweidoc deployment (default if unset: https://x.lumiclass.com)
QIWEIDOC_BASE_URL=https://x.lumiclass.com

# --- qiweidoc channel (optional) ---
# Comma-separated allowed group chat_ids; empty = all groups bound to the PAT's employee.
QIWEIDOC_ALLOWED_GROUPS=
# Default chat_id for cron / standalone notification delivery.
QIWEIDOC_HOME_CHAT_ID=
# If true, only react when the bot is @mentioned (default false = react to all in bound groups).
QIWEIDOC_REPLY_ON_ADDRESS_ONLY=
# Let the gateway accept messages from all users in bound groups.
GATEWAY_ALLOW_ALL_USERS=true

# --- model provider (Azure OpenAI / azure-foundry) ---
# Paste your Azure OpenAI key here in ~/.hermes/.env (keep it out of git).
AZURE_FOUNDRY_API_KEY=
